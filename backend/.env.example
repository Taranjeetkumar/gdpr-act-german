# ── GCP Project ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id

# ── AlloyDB ───────────────────────────────────────────────────────────────────
ALLOYDB_HOST=your-alloydb-private-ip
ALLOYDB_DB=gdprdb
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=your-password

# ── GCP Memorystore (Redis) ───────────────────────────────────────────────────
# MEMORYSTORE_HOST / MEMORYSTORE_PORT are used ONLY when NODE_ENV=production.
# The Dockerfile sets NODE_ENV=production automatically, so these values are
# picked up by Cloud Run without any extra configuration on your part.
MEMORYSTORE_HOST=your-memorystore-private-ip
MEMORYSTORE_PORT=6379

# MEMORYSTORE_HOST_LOCAL / MEMORYSTORE_PORT_LOCAL are used for local dev.
# Start a local Redis container:
#   docker run -d --name redis -p 6379:6379 redis:7-alpine
# Defaults to 127.0.0.1:6379 if left unset (these two lines are optional).
MEMORYSTORE_HOST_LOCAL=127.0.0.1
MEMORYSTORE_PORT_LOCAL=6379

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── NODE_ENV ──────────────────────────────────────────────────────────────────
# ⚠️  NEVER set this to "production" in your local .env.
#
#   LOCAL DEV  → leave as "development" (or omit entirely — defaults to development)
#   CLOUD RUN  → the Dockerfile sets NODE_ENV=production automatically
#
# Setting NODE_ENV=production locally causes the app to connect to the GCP
# Memorystore private VPC IP (10.x.x.x), which is unreachable from your
# machine → instant timeout on every Redis call.
NODE_ENV=development

PORT=8080

# ── Authentication ────────────────────────────────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS is NOT needed.
#
# Local dev:  run once →  gcloud auth application-default login
# Cloud Run:  the attached service account is used automatically (ADC).
#
# See: https://cloud.google.com/docs/authentication/application-default-credentials
-e 
# Static token for local admin panel (no Firebase account needed)
ADMIN_SECRET_TOKEN=gdpr-admin-secret-2025
