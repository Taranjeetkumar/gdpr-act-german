.env
.env.local
.env.*.local

# Google Cloud service account key — NEVER commit this
backend/service-account.json

# ─── Build outputs ───────────────────────────────────────────────────────────
frontend/dist/
frontend/build/
backend/dist/
backend/build/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Docker ──────────────────────────────────────────────────────────────────
# Dockerfile and docker-compose are intentionally tracked; ignore local overrides
docker-compose.override.yml

# ─── Misc ────────────────────────────────────────────────────────────────────
.cache/
coverage/
.nyc_output/
